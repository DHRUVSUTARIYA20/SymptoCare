{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend",
  "installCommand": "uv pip install --system -r requirements.txt",
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
